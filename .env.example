# ============================================
# AUTH0 & TOKEN VAULT CONFIGURATION
# ============================================
# Get these from your Auth0 Dashboard
# https://manage.auth0.com/dashboard

AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=YOUR_CLIENT_ID_HERE
AUTH0_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
AUTH0_API_AUDIENCE=https://your-tenant.auth0.com/api/v2

# ============================================
# TOKEN VAULT (Auth0 for AI Agents)
# ============================================
# Token Vault is Auth0's managed credential storage for AI agents
# Available in: https://auth0.com/product/ai-agents (free trial for hackathon)

TOKEN_VAULT_URL=https://your-tenant.auth0.com/api/v1/token-vault
TOKEN_VAULT_API_KEY=YOUR_TOKEN_VAULT_API_KEY

# Example: Your agent will call Token Vault like:
# GET /api/v1/token-vault/tokens/tableau
# Returns: { token: "ya29.a0AfH6SMBx...", expires_in: 3600 }

# ============================================
# EXTERNAL SERVICE INTEGRATIONS (for demo)
# ============================================

# Tableau (demo assumes mock/local)
TABLEAU_SERVER=http://localhost:3001/mock-tableau
TABLEAU_SITE=default
TABLEAU_USERNAME=demo@example.com

# Slack (optional - for notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# ============================================
# DEMO DATA
# ============================================
DEMO_MODE=true
MOCK_DATA_PATH=./demo-data
